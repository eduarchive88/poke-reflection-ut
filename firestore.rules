rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 교사(Teacher) 컬렉션: 본인 정보만 CRUD
    match /teachers/{teacherId} {
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
    }
    
    // 학급(Classes) 컬렉션: 
    match /classes/{classId} {
      allow create, update, delete: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow read: if true; 
    }
    
    // 학생(Students) 컬렉션:
    // 학생 세션이 비인증 상태이므로, 캔디 수/마지막 성찰 시간 업데이트를 위해 write 허용
    match /students/{studentId} {
      allow read: if true;
      allow write: if true; 
    }
    
    // 성찰노트(Reflections) 컬렉션:
    match /reflections/{reflectionId} {
      allow create: if true;
      allow read, update, delete: if true;
    }
    
    // 포켓몬 인벤토리(Pokemon Inventory) 컬렉션:
    match /pokemon_inventory/{inventoryId} {
      allow read, write: if true;
    }

    // 체육관(Gyms) 컬렉션:
    match /gyms/{classId} {
      allow read, write: if true;
    }

    // 친선전 요청(Battle Requests) 컬렉션:
    match /battle_requests/{requestId} {
      allow read, write, delete: if true;
    }
  }
}
