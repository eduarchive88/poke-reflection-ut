rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 교사(Teacher) 컬렉션: 본인 정보만 CRUD
    match /teachers/{teacherId} {
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
    }
    
    // 학급(Classes) 컬렉션: 
    // - 생성/수정/삭제: 로그인한 교사(teacherId와 uid가 일치)
    // - 읽기: 모든 로그인 유저(교사) 및 세션코드를 아는 학생(비인증 익명) 허용을 위해 조건부 오픈
    match /classes/{classId} {
      allow create, update, delete: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow read: if true; 
    }
    
    // 학생(Students) 컬렉션:
    // - 생성/수정/삭제: 해당 class의 담당 교사
    // - 읽기: 누구나 (학생들이 본인 정보 조회용, Cilent Side 필터링)
    match /students/{studentId} {
      allow read: if true;
      allow write: if request.auth != null; 
    }
    
    // 성찰노트(Reflections) 컬렉션:
    // - 생성: 누구나 (학생)
    // - 읽기/수정/삭제: 학생 본인이거나, 로그인한 교사
    match /reflections/{reflectionId} {
      allow create: if true;
      allow read, update, delete: if true; // 학생 세션이 비로그인(Custom) 상태이므로, 클라이언트 사이드 제어에 의존.
    }
    
    // 포켓몬 인벤토리(Pokemon Inventory) 컬렉션:
    // - 생성: 누구나 (학생)
    // - 읽기/수정: 누구나
    match /pokemon_inventory/{inventoryId} {
      allow read, write: if true; // 배틀 로직 및 경험치 로직을 위해 오픈 (학생 인증 방식이 제한적이므로)
    }
  }
}
